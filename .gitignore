# Obsidian trash
.trash/

# Obsidian workspace state - 자주 바뀌는 화면 배치/열린 파일 정보
.obsidian/workspace.json
.obsidian/workspaces.json
.obsidian/workspace-mobile.json

# Obsidian plugin files
.obsidian/plugins/

# Optional: 큰 첨부파일을 GitHub에 올리고 싶지 않다면 주석 해제
# 05_Resources/PDFs/
# 05_Resources/Media/

# Created by https://www.toptal.com/developers/gitignore/api/macos,windows
